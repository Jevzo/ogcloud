{
  "name": "@ogcloud/setup",
  "version": "0.1.3",
  "description": "Interactive CLI to generate config, deploy, update, and destroy OgCloud on Kubernetes using Helm",
  "keywords": [
    "ogcloud",
    "kubernetes",
    "helm",
    "minecraft"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "ogcloud-setup": "dist/setup.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
