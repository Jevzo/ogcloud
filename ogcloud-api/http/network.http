### Get network settings
GET {{baseUrl}}/api/v1/network
Authorization: Bearer {{accessToken}}

### Get network status
GET {{baseUrl}}/api/v1/network/status
Authorization: Bearer {{accessToken}}

### Get active network locks
GET {{baseUrl}}/api/v1/network/locks
Authorization: Bearer {{accessToken}}

### Update network settings
PUT {{baseUrl}}/api/v1/network
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "motd": {
    "global": "&e&lOgCloud &7| &7Production network&r\n&8> &7Welcome to the cluster",
    "maintenance": "&cNetwork maintenance in progress"
  },
  "versionName": {
    "global": "1.21.11",
    "maintenance": "Maintenance"
  },
  "maxPlayers": 500,
  "defaultGroup": "lobby",
  "maintenance": false,
  "maintenanceKickMessage": "&cThe network is currently under maintenance.",
  "tablist": {
    "header": "\n&e&lOgCloud\n&7Online: &a%onlinePlayers%&7/&a%maxPlayers%\n",
    "footer": "\n&7Proxy: &a%proxy% &8| &7Group: &a%group%\n&7Ping: &a%ping%ms\n"
  },
  "general": {
    "permissionSystemEnabled": true,
    "tablistEnabled": true,
    "proxyRoutingStrategy": "LOAD_BASED"
  }
}

### Toggle network maintenance
PUT {{baseUrl}}/api/v1/network/maintenance
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "maintenance": true
}

### Restart the network
POST {{baseUrl}}/api/v1/network/restart
Authorization: Bearer {{accessToken}}
