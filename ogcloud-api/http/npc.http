@npcGroup = lobby
@npcId = zerwas-lobby-1
@npcTextureValue = 
@npcTextureSignature = 

### List managed NPCs
GET {{baseUrl}}/api/v1/npcs?group={{npcGroup}}
Authorization: Bearer {{accessToken}}

### Get a managed NPC
GET {{baseUrl}}/api/v1/npcs/{{npcId}}
Authorization: Bearer {{accessToken}}

### Create a managed NPC
POST {{baseUrl}}/api/v1/npcs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "id": "{{npcId}}",
  "group": "{{npcGroup}}",
  "location": {
    "world": "world",
    "x": -10.682428801596709,
    "y": 88.0,
    "z": -3.2087608868244364,
    "yaw": -109.9513,
    "pitch": 0.7500092
  },
  "title": "&ePlay",
  "subtitle": "&7Join the lobby",
  "model": "ALEX",
  "skin": {
    "textureValue": "{{npcTextureValue}}",
    "textureSignature": "{{npcTextureSignature}}"
  },
  "lookAt": {
    "enabled": true,
    "radius": 5.0
  },
  "leftAction": {
    "type": "TRANSFER",
    "transfer": {
      "group": "{{npcGroup}}",
      "routingStrategy": "MOST_FILLED"
    }
  },
  "rightAction": {
    "type": "TRANSFER",
    "transfer": {
      "group": "{{npcGroup}}",
      "routingStrategy": "BALANCED"
    }
  }
}

### Update a managed NPC
PUT {{baseUrl}}/api/v1/npcs/{{npcId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "&6Updated Lobby NPC",
  "subtitle": "&7Right click to transfer",
  "lookAt": {
    "enabled": true,
    "radius": 6.0
  },
  "rightAction": {
    "type": "TRANSFER",
    "transfer": {
      "group": "{{npcGroup}}",
      "routingStrategy": "MOST_FILLED"
    }
  }
}

### Update a managed NPC skin
PUT {{baseUrl}}/api/v1/npcs/{{npcId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "model": "ALEX",
  "skin": {
    "textureValue": "{{npcTextureValue}}",
    "textureSignature": "{{npcTextureSignature}}"
  }
}

### Reset a managed NPC skin to the default profile
PUT {{baseUrl}}/api/v1/npcs/{{npcId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "clearSkin": true
}

### Delete a managed NPC
DELETE {{baseUrl}}/api/v1/npcs/{{npcId}}
Authorization: Bearer {{accessToken}}
