@webUserEmail = example-user@ogcloud.local
@updatedWebUserEmail = example-user-renamed@ogcloud.local

### List web users
GET {{baseUrl}}/api/v1/web/users?page=0&size=50&query=example-user
Authorization: Bearer {{accessToken}}

### Create a web user
POST {{baseUrl}}/api/v1/web/users
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "{{webUserEmail}}",
  "password": "replace-with-password",
  "role": "DEVELOPER"
}

### Update a web user
PUT {{baseUrl}}/api/v1/web/users/{{webUserEmail}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "{{updatedWebUserEmail}}",
  "password": "replace-with-another-password",
  "username": "Example User",
  "role": "ADMIN"
}

### Unlink a web user's Minecraft account
DELETE {{baseUrl}}/api/v1/web/users/{{updatedWebUserEmail}}/link
Authorization: Bearer {{accessToken}}

### Delete a web user
DELETE {{baseUrl}}/api/v1/web/users/{{updatedWebUserEmail}}
Authorization: Bearer {{accessToken}}
