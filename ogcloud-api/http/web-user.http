### List all web users (ADMIN or SERVICE)
GET {{baseUrl}}/api/v1/web/users
Authorization: Bearer {{accessToken}}

### List web users with pagination and query filtering
GET {{baseUrl}}/api/v1/web/users?page=0&size=50&query=dev-user
Authorization: Bearer {{accessToken}}

### Create a DEVELOPER user (ADMIN or SERVICE)
POST {{baseUrl}}/api/v1/web/users
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "dev-user@ogcloud.local",
  "password": "replace-with-a-password",
  "role": "DEVELOPER"
}

### Promote a user to ADMIN
PUT {{baseUrl}}/api/v1/web/users/dev-user@ogcloud.local
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "role": "ADMIN"
}

### Update a user's email
PUT {{baseUrl}}/api/v1/web/users/dev-user@ogcloud.local
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "dev-user-renamed@ogcloud.local"
}

### Update a user's username
PUT {{baseUrl}}/api/v1/web/users/dev-user-renamed@ogcloud.local
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "username": "Linked Display Name"
}

### Update a user's password
PUT {{baseUrl}}/api/v1/web/users/dev-user-renamed@ogcloud.local
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "password": "replace-with-another-password"
}

### Unlink a user's Minecraft account (resets username + clears linked player)
DELETE {{baseUrl}}/api/v1/web/users/dev-user-renamed@ogcloud.local/link
Authorization: Bearer {{accessToken}}

### Delete a user
DELETE {{baseUrl}}/api/v1/web/users/dev-user-renamed@ogcloud.local
Authorization: Bearer {{accessToken}}
