@adminEmail = service@ogcloud.local
@adminPassword = 

### Health (public)
GET {{baseUrl}}/health

### Login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
client.global.set("accessToken", response.body.accessToken);
client.global.set("refreshToken", response.body.refreshToken);
%}

### Refresh tokens
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

> {%
client.global.set("accessToken", response.body.accessToken);
client.global.set("refreshToken", response.body.refreshToken);
%}

### Revoke the current refresh token
POST {{baseUrl}}/api/v1/auth/revoke
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Revoke all refresh tokens for the authenticated user
POST {{baseUrl}}/api/v1/auth/revoke-all
Authorization: Bearer {{accessToken}}

### Update the authenticated user's own email
PUT {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "service-updated@ogcloud.local"
}

### Update the authenticated user's own password
PUT {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "password": "replace-with-a-new-password"
}

### Request an OTP to link the authenticated web account to an online Minecraft account
POST {{baseUrl}}/api/v1/auth/link/request
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "minecraftUsername": "Notch"
}

### Confirm account linking with the OTP shown in Minecraft chat
POST {{baseUrl}}/api/v1/auth/link/confirm
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "otp": "123456"
}

### Unlink the currently linked Minecraft account
DELETE {{baseUrl}}/api/v1/auth/link
Authorization: Bearer {{accessToken}}
