@existingGroupName = lobby
@managedGroupName = example-lobby

### List groups
GET {{baseUrl}}/api/v1/groups?page=0&size=50&query=lobby
Authorization: Bearer {{accessToken}}

### Get a group by name
GET {{baseUrl}}/api/v1/groups/{{existingGroupName}}
Authorization: Bearer {{accessToken}}

### Create a group
POST {{baseUrl}}/api/v1/groups
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "id": "{{managedGroupName}}",
  "type": "DYNAMIC",
  "templateBucket": "ogcloud-templates",
  "templatePath": "lobby",
  "templateVersion": "1.0.1",
  "scaling": {
    "minOnline": 1,
    "maxInstances": 2,
    "playersPerServer": 25,
    "scaleUpThreshold": 0.8,
    "scaleDownThreshold": 0.2,
    "cooldownSeconds": 60
  },
  "resources": {
    "memoryRequest": "512Mi",
    "memoryLimit": "1Gi",
    "cpuRequest": "250m",
    "cpuLimit": "1000m"
  },
  "jvmFlags": "-Xms512M -Xmx1024M",
  "drainTimeoutSeconds": 30,
  "serverImage": "ogwarsdev/paper:1.21.11",
  "runtimeProfile": "MODERN_1_21_11",
  "storageSize": "5Gi"
}

### Update a group
PUT {{baseUrl}}/api/v1/groups/{{managedGroupName}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "templateBucket": "ogcloud-templates",
  "templatePath": "lobby",
  "templateVersion": "1.0.2",
  "scaling": {
    "minOnline": 1,
    "maxInstances": 3,
    "playersPerServer": 30,
    "scaleUpThreshold": 0.85,
    "scaleDownThreshold": 0.15,
    "cooldownSeconds": 90
  },
  "resources": {
    "memoryRequest": "768Mi",
    "memoryLimit": "1536Mi",
    "cpuRequest": "300m",
    "cpuLimit": "1200m"
  },
  "jvmFlags": "-Xms768M -Xmx1024M",
  "drainTimeoutSeconds": 45,
  "serverImage": "ogwarsdev/paper:1.21.11",
  "runtimeProfile": "MODERN_1_21_11",
  "storageSize": "10Gi"
}

### Toggle group maintenance
PUT {{baseUrl}}/api/v1/groups/{{managedGroupName}}/maintenance
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "maintenance": true
}

### Restart a group
POST {{baseUrl}}/api/v1/groups/{{managedGroupName}}/restart
Authorization: Bearer {{accessToken}}

### Delete a group
DELETE {{baseUrl}}/api/v1/groups/{{managedGroupName}}
Authorization: Bearer {{accessToken}}
