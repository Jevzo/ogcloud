{
    "name": "@ogcloud/setup",
    "version": "0.1.7",
    "description": "Interactive CLI to generate config, deploy, update, and destroy OgCloud on Kubernetes using Helm",
    "keywords": [
        "ogcloud",
        "kubernetes",
        "helm",
        "minecraft"
    ],
    "engines": {
        "node": ">=18"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "bin": {
        "ogcloud-setup": "dist/setup.js"
    },
    "scripts": {
        "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "eslint . --max-warnings=0",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.13.14",
        "eslint": "^10.0.2",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "typescript-eslint": "^8.56.1",
        "typescript": "^5.8.2"
    },
    "publishConfig": {
        "access": "public"
    }
}
